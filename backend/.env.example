# Server Configuration
PORT=3000
NODE_ENV=production

# Google Calendar API Credentials
GOOGLE_CALENDAR_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="[REDACTED PRIVATE KEY]\nGOOGLE_CALENDAR_PROJECT_ID=your-project-id"
GOOGLE_CALENDAR_CALENDAR_ID=primary

# Email Configuration (SMTP)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Madame Marketing <noreply@madamemarketing.com>

# Admin Email (for receiving meeting notifications and invitations)
ADMIN_EMAIL=your-email@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500